import tkinter as tk
import random

SIZE = 4

root = tk.Tk()
root.title("2048 Pro")
root.geometry("500x650")
root.configure(bg="#faf8ef")

board = [[0]*SIZE for _ in range(SIZE)]
labels = [[None]*SIZE for _ in range(SIZE)]

score = 0

# ---------- COLORS ----------
colors = {
    0:"#cdc1b4", 2:"#eee4da", 4:"#ede0c8",
    8:"#f2b179", 16:"#f59563", 32:"#f67c5f",
    64:"#f65e3b", 128:"#edcf72", 256:"#edcc61",
    512:"#edc850", 1024:"#edc53f", 2048:"#edc22e"
}

# ---------- SCORE ----------
score_label = tk.Label(
    root,
    text="Score: 0",
    font=("Arial", 20, "bold"),
    bg="#faf8ef"
)
score_label.pack(pady=10)

# ---------- BOARD ----------
frame = tk.Frame(root, bg="#bbada0", bd=10)
frame.pack()

def create_grid():
    for i in range(SIZE):
        for j in range(SIZE):
            label = tk.Label(
                frame,
                text="",
                width=4,
                height=2,
                font=("Arial", 28, "bold"),
                bg=colors[0],
                relief="ridge",
                bd=5
            )
            label.grid(row=i, column=j, padx=5, pady=5)
            labels[i][j] = label

def update_ui():
    for i in range(SIZE):
        for j in range(SIZE):
            value = board[i][j]

            labels[i][j].config(
                text=str(value) if value else "",
                bg=colors.get(value, "#3c3a32"),
                fg="black" if value < 8 else "white"
            )

    score_label.config(text=f"Score: {score}")

# ---------- GAME LOGIC ----------
def add_tile():
    empty = [(i,j) for i in range(SIZE)
                    for j in range(SIZE)
                    if board[i][j] == 0]

    if empty:
        i,j = random.choice(empty)
        board[i][j] = 2 if random.random() < 0.9 else 4

def compress(row):
    new = [i for i in row if i != 0]
    new += [0]*(SIZE-len(new))
    return new

def merge(row):
    global score

    for i in range(SIZE-1):
        if row[i] == row[i+1] and row[i] != 0:
            row[i] *= 2
            score += row[i]
            row[i+1] = 0

            if row[i] == 2048:
                messagebox.showinfo("2048", "🎉 You reached 2048!")

    return row

def move_left():
    global board

    new_board = []

    for row in board:
        new = compress(row)
        new = merge(new)
        new = compress(new)
        new_board.append(new)

    board = new_board

def reverse():
    global board
    board = [row[::-1] for row in board]

def transpose():
    global board
    board = [list(row) for row in zip(*board)]

def move_right():
    reverse()
    move_left()
    reverse()

def move_up():
    transpose()
    move_left()
    transpose()

def move_down():
    transpose()
    move_right()
    transpose()

# ---------- GAME OVER ----------
def can_move():
    for i in range(SIZE):
        for j in range(SIZE):
            if board[i][j] == 0:
                return True

            if j < SIZE-1 and board[i][j] == board[i][j+1]:
                return True

            if i < SIZE-1 and board[i][j] == board[i+1][j]:
                return True

    return False

# ---------- CONTROLS ----------
def key_press(event):
    old = [row[:] for row in board]

    if event.keysym == "Left":
        move_left()

    elif event.keysym == "Right":
        move_right()

    elif event.keysym == "Up":
        move_up()

    elif event.keysym == "Down":
        move_down()

    else:
        return

    if old != board:
        add_tile()
        update_ui()

    if not can_move():
        game_over()

# ---------- GAME OVER ----------
def game_over():
    result.config(text="💀 GAME OVER")

# ---------- RESTART ----------
def restart_game():
    global board, score

    board = [[0]*SIZE for _ in range(SIZE)]
    score = 0

    add_tile()
    add_tile()

    result.config(text="")
    update_ui()

# ---------- RESULT ----------
result = tk.Label(
    root,
    text="",
    font=("Arial", 22, "bold"),
    bg="#faf8ef",
    fg="red"
)
result.pack(pady=10)

# ---------- BUTTON ----------
restart_btn = tk.Button(
    root,
    text="🔄 Restart",
    font=("Arial", 16, "bold"),
    command=restart_game
)
restart_btn.pack(pady=10)

# ---------- START ----------
create_grid()

add_tile()
add_tile()

update_ui()

root.bind("<Key>", key_press)

root.mainloop()