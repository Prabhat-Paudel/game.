import tkinter as tk
import random

SIZE = 4
CELL_SIZE = 100
PADDING = 10

root = tk.Tk()
root.title("2048 Game")

frame = tk.Frame(root, bg="#bbada0")
frame.pack()

board = [[0]*SIZE for _ in range(SIZE)]
labels = [[None]*SIZE for _ in range(SIZE)]

# ---------- COLORS ----------
colors = {
    0:"#cdc1b4", 2:"#eee4da", 4:"#ede0c8", 8:"#f2b179",
    16:"#f59563", 32:"#f67c5f", 64:"#f65e3b",
    128:"#edcf72", 256:"#edcc61", 512:"#edc850",
    1024:"#edc53f", 2048:"#edc22e"
}

# ---------- UI ----------
def create_grid():
    for i in range(SIZE):
        for j in range(SIZE):
            label = tk.Label(
                frame, text="",
                width=4, height=2,
                font=("Arial", 24, "bold"),
                bg=colors[0]
            )
            label.grid(row=i, column=j, padx=5, pady=5)
            labels[i][j] = label

def update_ui():
    for i in range(SIZE):
        for j in range(SIZE):
            value = board[i][j]
            labels[i][j].config(
                text=str(value) if value else "",
                bg=colors.get(value, "#3c3a32"),
                fg="black" if value < 8 else "white"
            )

# ---------- GAME LOGIC ----------
def add_tile():
    empty = [(i,j) for i in range(SIZE) for j in range(SIZE) if board[i][j]==0]
    if empty:
        i,j = random.choice(empty)
        board[i][j] = 2 if random.random()<0.9 else 4

def compress(row):
    new = [i for i in row if i != 0]
    new += [0]*(SIZE-len(new))
    return new

def merge(row):
    for i in range(SIZE-1):
        if row[i] == row[i+1] and row[i] != 0:
            row[i] *= 2
            row[i+1] = 0
    return row

def move_left():
    global board
    new_board = []
    for row in board:
        new = compress(row)
        new = merge(new)
        new = compress(new)
        new_board.append(new)
    board = new_board

def reverse():
    global board
    board = [row[::-1] for row in board]

def transpose():
    global board
    board = [list(row) for row in zip(*board)]

def move_right():
    reverse()
    move_left()
    reverse()

def move_up():
    transpose()
    move_left()
    transpose()

def move_down():
    transpose()
    move_right()
    transpose()

# ---------- CONTROLS ----------
def key_press(event):
    key = event.keysym

    if key == "Left":
        move_left()
    elif key == "Right":
        move_right()
    elif key == "Up":
        move_up()
    elif key == "Down":
        move_down()
    else:
        return

    add_tile()
    update_ui()

# ---------- START ----------
create_grid()
add_tile()
add_tile()
update_ui()

root.bind("<Key>", key_press)

root.mainloop()